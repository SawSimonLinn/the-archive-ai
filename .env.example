# Supabase — find these in your Supabase project settings > API
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key   # server-only, never expose to the browser

# OpenAI — used for embeddings (text-embedding-3-small) and chat (gpt-4o-mini)
OPENAI_API_KEY=sk-...

# Stripe — use production/live mode values before deploying
STRIPE_SECRET_KEY=sk_live_...
STRIPE_WEBHOOK_SECRET=whsec_...          # from Stripe Dashboard > Webhooks > signing secret
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_live_...

STRIPE_PRO_PRICE_ID=price_live_pro_monthly
STRIPE_TEAM_PRICE_ID=price_live_team_monthly
STRIPE_LIVE_TEST_PRICE_ID=price_live_test_monthly

# App URL fallback — auth, billing, and callback routes prefer the current
# request/browser host. Set this as a fallback for jobs or environments where
# the app cannot infer a host.
NEXT_PUBLIC_APP_URL=https://thearchiveai.xyz
# NEXT_PUBLIC_SITE_URL=https://thearchiveai.xyz
